# ===========================================
# OptimizerV6 - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ─── Database (local Docker) ──────────────────
DATABASE_URL=postgresql://rectangled:YOUR_DB_PASSWORD@localhost:5432/rectangled_v6

# ─── Redis (local Docker) ─────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters in production
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── API Server ───────────────────────────────
NODE_ENV=development
API_PORT=3001
API_URL=http://localhost:3001

# ─── Frontend ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Google Business Profile (Connector) ──────
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
GBP_REDIRECT_URI=http://localhost:3000/dashboard/connectors/callback
# Optional: Used for resolving Google Maps links to Place IDs.
# If not set, OAuth access token is used instead (requires Places API enabled on the same project).
GOOGLE_API_KEY=

# ─── AI — OpenRouter ─────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# ─── Email — Resend ──────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@rectangled.io

# ─── Billing — Razorpay ──────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── WhatsApp — WapiSnap ─────────────────────
WAPISNAP_API_KEY=
WAPISNAP_INSTANCE_ID=
